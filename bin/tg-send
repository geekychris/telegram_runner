#!/usr/bin/env bash
# tg-send — Send a message to Telegram from anywhere
# Auto-bootstraps the venv on first run. Works from any directory.
#
# Usage:
#   tg-send "Deploy complete"
#   echo "Build failed" | tg-send -
#   tg-send -t 123456789 "Alert: disk at 95%"
#   make test && tg-send "Tests passed" || tg-send "Tests FAILED"
#
set -euo pipefail

# Resolve the project root (follows symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd "$BIN_DIR/.." && pwd)"

VENV="$PROJECT_DIR/.venv"

# Auto-bootstrap
if [[ ! -f "$VENV/bin/tg-send" ]]; then
    echo "[tg-send] First run — installing..." >&2
    python3 -m venv "$VENV" 2>/dev/null || true
    "$VENV/bin/pip" install --quiet --upgrade pip
    "$VENV/bin/pip" install --quiet -e "$PROJECT_DIR"
    echo "[tg-send] Ready." >&2
fi

exec "$VENV/bin/tg-send" "$@"
